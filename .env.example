# Database Configuration
# If using Docker (recommended): postgresql://pulse_user:pulse_password@localhost:5433/pulse_db
# If using local PostgreSQL: Update with your credentials
DATABASE_URL=postgresql://pulse_user:pulse_password@localhost:5433/pulse_db

# Service Mode
# Set to "false" for standalone mode (won't call Genesis/Orbit services)
# Set to "true" when running in full Synapse ecosystem
ENABLE_EXTERNAL_SERVICES=false

# API Keys (REQUIRED for full functionality)
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key

# YouTube Data API v3
# Get your key from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key

# Reddit API
# Get credentials from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=pulse_monitor/1.0

# URLs of sibling services (Synapse ecosystem)
# Only used if ENABLE_EXTERNAL_SERVICES=true
GENESIS_SERVICE_URL=http://localhost:8001
FORGE_SERVICE_URL=http://localhost:8002
ORBIT_SERVICE_URL=http://localhost:8004
